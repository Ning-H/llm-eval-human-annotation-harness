# Local development:
# Copy this file to `.env` and fill in real API keys.
# Production on Streamlit Community Cloud:
# Add the same names under App settings > Secrets.

# Required only when generating real model responses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Cheap default comparison models. Override if desired.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-5-nano

# Local SQLite path. For production multi-user annotation, replace SQLite with
# persistent storage before using private data.
ANNOTATION_DB_PATH=data/annotations.db

# Default UI identities. Not secrets.
RATER_ID=demo_rater
ADJUDICATOR_ID=lead_reviewer
